# ==============================================================================
# PolyYield Configurations (.env)
# ==============================================================================

# Server binding
HOST=127.0.0.1
PORT=8080
API_SECRET=your_super_secret_api_key_here

# ------------------------------------------------------------------------------
# Alchemy Node Setup Instructions:
# 1. Sign up at https://www.alchemy.com/
# 2. Create a new App in your dashboard.
# 3. Select Chain: Polygon, Network: Polygon Mainnet (or Amoy for Testnet).
# 4. Copy the HTTP API Key / HTTPS URL and set it below.
# ------------------------------------------------------------------------------
ALCHEMY_API_KEY=your_alchemy_api_key_here
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here

# ------------------------------------------------------------------------------
# Web3 / Polymarket Settings
# Chain IDs:
# - Mainnet: 137
# - Amoy Testnet: 80002 (USDC address on Amoy: 0x41e94eb019c0762f9bfcf9fb1e58725bfb0e7582)
# ------------------------------------------------------------------------------
POLYGON_CHAIN_ID=137
POLYGON_USDC_CONTRACT=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174

# ------------------------------------------------------------------------------
# Webhooks and Telemetry:
#
# Telegram Setup Instructions:
# 1. Chat with @BotFather on Telegram to create a new bot. Copy the API Token.
# 2. Start a chat with @userinfobot to find your Chat ID.
# 3. Fill in TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID below.
#
# Discord Setup Instructions:
# 1. Open your Discord server, go to Server Settings -> Integrations -> Webhooks.
# 2. Click "Create Webhook", configure the channel, and click "Copy Webhook URL".
# 3. Fill in DISCORD_WEBHOOK_URL below.
# ------------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
